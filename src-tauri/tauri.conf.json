{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open GFX Board",
  "version": "0.1.2",
  "identifier": "com.alayshoo.open-gfx-board",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Open GFX Board",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "backgroundColor": "#000000",
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Open GFX Board",
        "width": 420,
        "height": 300,
        "decorations": false,
        "center": true,
        "resizable": false,
        "url": "splashscreen.html",
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../build": "_up_/build"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
