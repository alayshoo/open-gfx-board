{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Open GFX Board",
  "version": "1.1.0",
  "identifier": "com.alayshoo.open-gfx-board",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Open GFX Board",
        "width": 1200,
        "height": 800,
        "decorations": false,
        "backgroundColor": "#000000",
        "visible": false
      },
      {
        "label": "splashscreen",
        "title": "Open GFX Board",
        "width": 420,
        "height": 300,
        "decorations": false,
        "center": true,
        "resizable": false,
        "url": "splashscreen.html",
        "backgroundColor": "#000000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEU5MzNBODM3NUM0RTREQ0YKUldUUFRVNWNONmd6NllRdlgxUnpPV0Q4dXNCOWpuSVJNRlVwMEgzLytDNzNwNGlSeXdqckQ3WHYK",
      "endpoints": [
        "https://github.com/alayshoo/open-gfx-board/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signingIdentity": null
    },
    "resources": {
      "../build": "_up_/build",
      "plugins": "_up_/plugins"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
